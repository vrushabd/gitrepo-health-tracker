# RepoPulse AI Backend Environment Variables

# Server
PORT=3001
NODE_ENV=development

# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://username:password@ep-xxxx.neon.tech/repopulse?sslmode=require"

# Redis (for BullMQ - optional, use local Redis or Upstash)
REDIS_URL="redis://localhost:6379"

# Google Gemini API
GEMINI_API_KEY="your-gemini-api-key-here"

# Temp directory for cloning repos
REPOS_DIR="/tmp/repopulse-repos"

# Analysis settings
MAX_COMMITS=1500
ANALYSIS_TIMEOUT_MS=300000
